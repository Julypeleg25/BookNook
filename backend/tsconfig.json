{
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "../",
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@controllers/*": [
        "./src/controllers/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@middlewares/*": [
        "./src/middlewares/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
      "@repositories/*": [
        "./src/repositories/*"
      ],
      "@models/*": [
        "./src/models/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@shared/schemas/*": [
        "../packages/shared/src/schemas/*"
      ],
      "@shared/dtos/*": [
        "../packages/shared/src/dtos/*"
      ],
      "@shared/*": [
        "../packages/shared/src/*"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "../packages/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}